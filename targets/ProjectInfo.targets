<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <!-- Exactly one generated file per project -->
    <ProjectInfoRelFile>Generated\ProjectInfo.g.cs</ProjectInfoRelFile>
    <ProjectInfoAbsFile>$(MSBuildProjectDirectory)\$(ProjectInfoRelFile)</ProjectInfoAbsFile>

    <!-- Safer namespace -->
    <_ProjectInfoNamespace Condition="'$(RootNamespace)'!=''">$(RootNamespace).Generated</_ProjectInfoNamespace>
    <_ProjectInfoNamespace Condition="'$(_ProjectInfoNamespace)'==''">$(MSBuildProjectName).Generated</_ProjectInfoNamespace>

    <!-- IMPORTANT: must be %3B (escaped semicolon), not ';' -->
    <_Semi>%3B</_Semi>
  </PropertyGroup>

  <!-- Generate before compile so file exists -->
  <Target Name="GenerateProjectInfo"
          BeforeTargets="CoreCompile"
          Condition="'$(MSBuildProjectExtension)'=='.csproj'">

    <MakeDir Directories="$(MSBuildProjectDirectory)\Generated" />

    <!-- Keep this easy to edit. NOTE: do NOT use literal ';' anywhere, use $(_Semi). -->
    <PropertyGroup>
      <_ProjectInfoText>
<![CDATA[// <auto-generated/>
#nullable enable

/** @file ProjectInfo.g.cs

    @brief Build-time project metadata exposed to tests and tooling.
	
    @details
      - Generated by MSBuild
      - Provides stable absolute paths regardless of checkout location
	  
    @note This file is generated. Do not edit manually.
*/
namespace $(_ProjectInfoNamespace)$(_Semi)

/// @brief Provides absolute paths for the current build context.
public static class ProjectInfo
    {
    /// @brief MSBuild solution name.
    public const string SolutionName = @"$(SolutionName)"$(_Semi)

    /// @brief MSBuild project name.
    public const string ProjectName = @"$(MSBuildProjectName)"$(_Semi)

    /// @brief Absolute path to the solution root directory.
    public const string  SolutionDir  = @"$(SolutionDir)"$(_Semi)
	public static DirectoryInfo SolutionPath = new(@"$(SolutionDir)")$(_Semi)

    /// @brief Absolute path to the project root directory.
    public const string ProjectDir  = @"$(ProjectDir)"$(_Semi)
    public static DirectoryInfo ProjectPath  = new(@"$(ProjectDir)")$(_Semi)
    }
]]>
      </_ProjectInfoText>
    </PropertyGroup>

    <!-- Write the whole blob as ONE item (no literal semicolons => no splitting) -->
    <WriteLinesToFile File="$(ProjectInfoAbsFile)"
                      Lines="$(_ProjectInfoText)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />
  </Target>

  <!-- Prevent duplicates and keep only this one generated file compiled -->
  <ItemGroup>
    <!-- Remove any other generated cs under Generated to avoid future duplicates -->
    <Compile Remove="$(ProjectInfoRelFile)" />
    <Compile Include="$(ProjectInfoRelFile)" Visible="true" />
    <None Include="$(ProjectInfoRelFile)" Visible="true" />
  </ItemGroup>

</Project>
